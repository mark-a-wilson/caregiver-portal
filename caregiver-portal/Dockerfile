FROM node:18-alpine

WORKDIR /app

# Set environment variables using build arguments
ARG VITE_API_URL
ARG VITE_ENV
ARG VITE_BCSC_CLIENT_ID
ARG VITE_BCSC_AUTHORITY
ARG VITE_KILN_URL
ARG VITE_USE_KONG_OIDC
ARG VITE_ACCESS_CODE_RESET

ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_ENV=${VITE_ENV}
ENV VITE_BCSC_CLIENT_ID=${VITE_BCSC_CLIENT_ID}
ENV VITE_BCSC_AUTHORITY=${VITE_BCSC_AUTHORITY}
ENV VITE_KILN_URL=${VITE_KILN_URL}
ENV VITE_USE_KONG_OIDC=${VITE_USE_KONG_OIDC}
ENV VITE_ACCESS_CODE_RESET=${VITE_ACCESS_CODE_RESET}

COPY package.json . 
RUN npm install

RUN npm i -g serve

COPY . .

RUN npm run build

EXPOSE 8080

CMD [ "serve", "-s", "dist", "-l", "8080" ]
